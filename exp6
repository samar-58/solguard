#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include <stdlib.h>

#define MAX 100

char code[MAX][50];
int n = 0;

// Check if string is number
int isNumber(char *str) {
    for (int i = 0; str[i]; i++) {
        if (!isdigit(str[i])) return 0;
    }
    return 1;
}

// Constant Folding
void constantFolding() {
    char res[10], op;
    int a, b;

    for (int i = 0; i < n; i++) {
        if (sscanf(code[i], "%*s = %d %c %d", &a, &op, &b) == 3) {
            int result;
            switch (op) {
                case '+': result = a + b; break;
                case '-': result = a - b; break;
                case '*': result = a * b; break;
                case '/': result = b != 0 ? a / b : 0; break;
            }
            sprintf(code[i], "%c = %d", code[i][0], result);
        }
    }
}

// Algebraic Simplification
void algebraicSimplification() {
    char lhs, op, op1[10], op2[10];

    for (int i = 0; i < n; i++) {
        if (sscanf(code[i], "%c = %s %c %s", &lhs, op1, &op, op2) == 4) {
            if (strcmp(op2, "0") == 0 && op == '+')
                sprintf(code[i], "%c = %s", lhs, op1);

            if (strcmp(op2, "1") == 0 && op == '*')
                sprintf(code[i], "%c = %s", lhs, op1);
        }
    }
}

// Strength Reduction
void strengthReduction() {
    char lhs, op, op1[10], op2[10];

    for (int i = 0; i < n; i++) {
        if (sscanf(code[i], "%c = %s %c %s", &lhs, op1, &op, op2) == 4) {
            if (strcmp(op2, "2") == 0 && op == '*') {
                sprintf(code[i], "%c = %s + %s", lhs, op1, op1);
            }
        }
    }
}

// Dead Code Elimination (very basic)
void deadCodeElimination() {
    for (int i = 0; i < n - 1; i++) {
        char var = code[i][0];
        int used = 0;

        for (int j = i + 1; j < n; j++) {
            if (strchr(code[j], var)) {
                used = 1;
                break;
            }
        }

        if (!used) {
            strcpy(code[i], ""); // remove line
        }
    }
}

// Print code
void printCode() {
    for (int i = 0; i < n; i++) {
        if (strlen(code[i]) > 0)
            printf("%s\n", code[i]);
    }
}

int main() {
    printf("Enter number of statements: ");
    scanf("%d", &n);
    getchar();

    printf("Enter code (3-address form):\n");
    for (int i = 0; i < n; i++) {
        fgets(code[i], sizeof(code[i]), stdin);
        code[i][strcspn(code[i], "\n")] = 0;
    }

    printf("\n--- Original Code ---\n");
    printCode();

    constantFolding();
    algebraicSimplification();
    strengthReduction();
    deadCodeElimination();

    printf("\n--- Optimized Code ---\n");
    printCode();

    return 0;
}

